generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id        String   @id @default(uuid())
  name      String
  mobile    String
  email     String
  location  String
  answers   Json     @default("[]")
  result    Json?
  status    String   @default("Partial") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id        String   @id @default(uuid())
  text      String
  options   Json     
  category  String?  @default("neutral")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}