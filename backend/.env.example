# Server
PORT=5001
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Database (choose either DATABASE_URL or individual DB_* vars)
# DATABASE_URL=postgresql://user:password@localhost:5432/career_care
DB_HOST=localhost
DB_PORT=5432
DB_USER=ajeet
DB_PASSWORD=
DB_NAME=career_care

# OTP behavior
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=45
OTP_MAX_ATTEMPTS=5
EXPOSE_DEV_OTP=true

# Times Messaging API
SMS_API_DOMAIN=sms.timesapi.in
SMS_API_PATH=/api/v1/send
SMS_API_USERNAME=ednovateotp.trans
SMS_API_PASSWORD=
SMS_SENDER_ID=EDNVTE
SMS_DLT_CONTENT_ID=1107177546916134979
SMS_UNICODE=false
SMS_PLATFORM_NAME=Ednovate
SMS_TIMEOUT_MS=12000
SMS_OTP_TEMPLATE=Your OTP for Ednovate is {{otp}}. It is valid for 10 minutes.
SMS_INCLUDE_CORRELATION_ID=false
